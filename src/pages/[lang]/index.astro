---
// Non-default locales: /es, /de, /tr. EN lives at the root (index.astro), not here.
import Landing from "../../components/landing/Landing.astro";
import { languages, defaultLang, type Lang } from "../../i18n/ui";

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[])
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---
<Landing lang={lang} />
