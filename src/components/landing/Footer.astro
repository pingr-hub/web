---
// Site footer · brand + tagline, with legal/links condensed to a single row.
import { useTranslations, langPath, type Lang } from "../../i18n/ui";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = langPath(lang);
---
<footer class="lp-footer">
  <div class="lp-wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <a class="lp-brand" href={`${base}/#top`}><span class="mark"><svg viewBox="159 140 76 76" fill="currentColor" aria-hidden="true"><path d="M235,159L235,197C235,207.486 226.486,216 216,216L178,216C167.514,216 159,207.486 159,197L159,159C159,148.514 167.514,140 178,140L216,140C226.486,140 235,148.514 235,159ZM203.259,151.176C191.415,151.176 181.8,160.792 181.8,172.635C181.8,184.479 191.415,194.094 203.259,194.094C215.102,194.094 224.718,184.479 224.718,172.635C224.718,160.792 215.102,151.176 203.259,151.176Z"/></svg></span>Pingr</a>
      </div>
      <nav class="foot-links" aria-label="Footer">
        <a href={`${base}/privacy/`}>{t("nav_privacy")}</a>
        <a href={`${base}/terms/`}>{t("nav_terms")}</a>
        <a href={`${base}/refund/`}>{t("nav_refund")}</a>
      </nav>
    </div>
  </div>
</footer>
