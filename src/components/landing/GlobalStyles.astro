---
// All non-utility CSS for the landing system: :root tokens, reset, nested
// selectors, pseudo-elements, state modifiers, media queries, scrollbar.
// Lives in an UNLAYERED <style is:global> block — UnoCSS emits its output
// in cascade layers (preflights → shortcuts → default), so an unlayered
// stylesheet ALWAYS wins over them regardless of source order. That fixes
// overrides like .row:first-child / .seg-i.on being clobbered by the .row
// / .seg-i shortcut rules, and keeps .astro class names untouched.
// uno.config.ts now holds only tokens-as-theme + shortcuts.
---
<style is:global>
:root{
  --bg:#0E0F12; --bg-raised:#15171C; --bg-overlay:#1B1E24;
  --bg-hover:#1E2229; --bg-selected:#232834;
  --fg:#E8E8EC; --fg-muted:#9499A3; --fg-dim:#60656F;
  --border:#24272E; --border-strong:#363A44;
  --accent:#7DC8FF; --accent-dim:#4A7FA6;
  --ch-github:#C4D1DE; --ch-gmail:#E6A186; --ch-whatsapp:#8FD3A8;
  --shadow-soft:0 1px 2px rgba(0,0,0,.4),0 8px 24px rgba(0,0,0,.25);
  --ft:'Inter',ui-sans-serif,system-ui,sans-serif;
  --fm:'JetBrains Mono',ui-monospace,monospace;
  --r-sm:6px;--r-md:10px;--r-lg:14px;--r-pill:9999px;
  --ai:#C6B8F4; --ai-dim:#786AAE; --warn:#E6A186;
  --ch-slack:#D9A1CE; --ch-twitter:#8FC9D6; --ch-facebook:#94A8EC; --ch-plane:#E4C079;
  --ch-telegram:#8FBFEA; --ch-discord:#ADA6E6; --ch-linear:#C3B6E8; --ch-notion:#CBC7BE;
  --ch-jira:#8FB4E8; --ch-gitlab:#E6A98E;
  --lp-max:1200px; --lp-pad:clamp(20px,5vw,44px); --lp-ink:#0A0D10;
  --lp-line:var(--border); --lp-line-2:var(--border-strong);
}
*{box-sizing:border-box;margin:0;padding:0}
a{color:inherit}
html{background:#07080A;scroll-behavior:smooth}
body{background:#07080A;color:var(--fg);font-family:var(--ft);line-height:1.6;-webkit-font-smoothing:antialiased;letter-spacing:-0.006em;padding:0;overflow-x:hidden}
img{max-width:100%;display:block}
::selection{background:rgba(125,200,255,.24)}

/* ---------- nested children + pseudo + state (cannot be shortcuts) ---------- */
.tb-logo svg{width:14px;height:14px;display:block}
.tb-ico:hover{background:var(--bg-hover);color:var(--fg)}
.tb-ico svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.5}
.search-lite svg{width:12px;height:12px;stroke:var(--fg-muted);fill:none;stroke-width:1.5}
.search-lite input{flex:1;background:transparent;border:none;outline:none;color:var(--fg);font-family:var(--ft);font-size:12px}
.search-lite input::placeholder{color:var(--fg-dim)}
.search-lite .kbd{font-family:var(--fm);font-size:9px;color:var(--fg-muted);background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:1px 4px}
.filter.on{color:var(--fg);background:var(--bg-selected);border-color:var(--border-strong)}
.filter .cdot{width:6px;height:6px;border-radius:9999px;background:var(--fg-dim)}
.filter.on .cdot{background:var(--accent)}
.scroll::-webkit-scrollbar{width:6px}
.scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
/* Search match highlight inside notification rows */
.nrow mark{background:rgba(125,200,255,.22);color:inherit;border-radius:3px;padding:0 1px}
/* Fixed-height mocks: popover is height-locked, .pop is h-full flex-col, so the
   scroll body (flex-1) must shrink to fit — min-height:0 + overflow-y:auto keeps
   rows inside a constant box instead of growing the popover. */
.popover[style*="height"] .scroll{min-height:0;overflow-y:auto;overflow-x:hidden}
.nrow.snoozed{opacity:.6}
.nrow:not(.unread) .rti{color:var(--fg-muted);font-weight:400}
/* Hero live feed: rows start hidden, revealed by motion one-by-one.
   Guarded by html.js-anim (added pre-paint) so no-JS keeps rows visible. */
html.js-anim [data-hero-feed] .nrow{opacity:0;transform:translateY(8px)}
.avatar .ch{position:absolute;right:-2px;bottom:-2px;width:10px;height:10px;border-radius:9999px;border:2px solid var(--bg-raised);background:var(--ch-github)}
.avatar .ch.gmail{background:var(--ch-gmail)}.avatar .ch.whatsapp{background:var(--ch-whatsapp)}
.avatar .ch.slack{background:var(--ch-slack)} .avatar .ch.twitter{background:var(--ch-twitter)}
.avatar .ch.facebook{background:var(--ch-facebook)} .avatar .ch.plane{background:var(--ch-plane)}
.avatar .ch.telegram{background:var(--ch-telegram)} .avatar .ch.discord{background:var(--ch-discord)}
.avatar.unread::after{content:"";position:absolute;top:-2px;left:-2px;width:8px;height:8px;border-radius:9999px;background:var(--accent);border:2px solid var(--bg-raised)}
.snooze-chip svg{width:10px;height:10px;stroke:var(--accent);fill:none;stroke-width:1.5}
.chip-ch .sw-dot{width:6px;height:6px;border-radius:9999px}
.statusbar .dots{display:flex;gap:6px;align-items:center}
.statusbar .dots .d{width:5px;height:5px;border-radius:9999px;background:var(--fg-dim)}
.statusbar .dots .d.on{background:var(--accent)}
.statusbar .kbd{font-family:var(--fm);font-size:9px;color:var(--fg-muted);background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:1px 5px}
.seg-i.on{background:var(--bg-selected);color:var(--fg)}
.sh-hd .search-full{flex:1;display:flex;align-items:center;gap:8px;background:var(--bg-raised);border:1px solid var(--border-strong);border-radius:var(--r-sm);padding:8px 10px;box-shadow:0 0 0 3px rgba(125,200,255,.08)}
.sh-hd .search-full svg{width:13px;height:13px;stroke:var(--accent);fill:none;stroke-width:1.5}
.sh-hd .search-full input{flex:1;background:transparent;border:none;outline:none;color:var(--fg);font-size:13px}
.sh-hd .close{font-family:var(--fm);font-size:10px;color:var(--fg-muted);letter-spacing:.05em;cursor:pointer}
.snooze-inline .hd{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px}
.snooze-inline .hd .t{font-size:13px;font-weight:500}
.snooze-inline .hd .s{font-family:var(--fm);font-size:10px;letter-spacing:.05em;color:var(--fg-muted)}
.snooze-inline .chips{display:flex;flex-wrap:wrap;gap:5px}
.cbtn{transition:background .35s ease,color .35s ease,border-color .35s ease}
.cbtn.on{background:var(--accent);color:var(--bg);border-color:var(--accent)}
.snooze-badge{display:inline-flex;align-items:center;gap:3px;font-family:var(--fm);font-size:9px;letter-spacing:.04em;color:var(--fg-muted);opacity:0;transform:translateX(-4px);transition:opacity .4s ease,transform .4s ease}
.snooze-badge.in{opacity:1;transform:translateX(0)}
.macbar .l{display:flex;align-items:center;gap:14px}
.macbar .apple{display:flex;align-items:center;justify-content:center;color:#D0D3D8}
.macbar .apple svg{display:block}
.macbar .mitm{font-size:11px;opacity:.75}
.macbar .r{display:flex;align-items:center;gap:12px;font-size:11px}
.macbar .r .pingr-tray{display:inline-flex;align-items:center;gap:4px;padding:2px 6px;border-radius:4px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08)}
.macbar .r .pingr-tray .ic{width:12px;height:12px;display:flex;align-items:center;justify-content:center}
.macbar .r .pingr-tray .ic svg{width:100%;height:100%;display:block}
.macbar .r .pingr-tray .n{font-family:var(--fm);font-size:10px;color:var(--accent)}
.spark{display:inline-flex;width:12px;height:12px;flex:none;color:var(--ai)}
.spark svg{width:12px;height:12px;fill:currentColor;stroke:none}
.ai-eyebrow{display:inline-flex;align-items:center;gap:6px;font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--ai)}
.brief-body b{font-weight:500}
.brief-body .hl{color:var(--accent);font-variant-numeric:tabular-nums}
@keyframes lp-pulse{0%,100%{box-shadow:0 0 0 0 rgba(125,200,255,.45)}50%{box-shadow:0 0 0 4px rgba(125,200,255,0)}}
.brief-body .hl.pulse{border-radius:4px;animation:lp-pulse .9s ease-out}
.brief-meta .live{width:6px;height:6px;border-radius:9999px;background:var(--ai);box-shadow:0 0 0 3px rgba(198,184,244,.14)}
/* AI generation skeleton — shimmering placeholder blocks shown before typed text. */
.ai-skel{position:relative;overflow:hidden;border-radius:6px;background:var(--bg-raised)}
.ai-skel.line{height:9px;border-radius:4px}
.ai-skel::after{content:"";position:absolute;inset:0;transform:translateX(-100%);background:linear-gradient(90deg,transparent,rgba(198,184,244,.16),transparent);animation:lp-shimmer 1.1s ease-in-out infinite}
@keyframes lp-shimmer{100%{transform:translateX(100%)}}
.ai-caret{display:inline-block;width:1.5px;height:1em;margin-left:1px;vertical-align:-2px;background:var(--ai);animation:lp-blink 1s steps(1) infinite}
@keyframes lp-blink{50%{opacity:0}}
/* AI "typing" indicator — three bouncing dots shown while the assistant thinks. */
.ai-dots{display:inline-flex;align-items:center;gap:4px;padding:2px 0}
.ai-dots i{width:5px;height:5px;border-radius:9999px;background:var(--ai);opacity:.5;animation:lp-dot-bounce 1s ease-in-out infinite}
.ai-dots i:nth-child(2){animation-delay:.15s}
.ai-dots i:nth-child(3){animation-delay:.3s}
@keyframes lp-dot-bounce{0%,60%,100%{transform:translateY(0);opacity:.45}30%{transform:translateY(-4px);opacity:1}}
.brief-card::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:linear-gradient(90deg,transparent,var(--ai-dim),transparent);opacity:.7}
.ai-mod-t .n{font-family:var(--fm);font-size:11px;color:var(--fg-dim);letter-spacing:.03em;font-weight:400}
.task-row:first-child{border-top:none}
.check:hover{border-color:var(--fg-muted)}
.check.done{background:var(--accent);border-color:var(--accent)}
.check.done::after{content:"";position:absolute;left:4.5px;top:1.5px;width:4px;height:8px;border:solid var(--bg);border-width:0 2px 2px 0;transform:rotate(45deg)}
.task-row.done .tt{color:var(--fg-dim);text-decoration:line-through;text-decoration-color:var(--border-strong)}
.task-b .tt{font-size:13px;line-height:1.4;color:var(--fg)}
.task-src{display:flex;align-items:center;gap:6px;margin-top:3px;font-family:var(--fm);font-size:10px;letter-spacing:.03em;color:var(--fg-muted)}
.task-src .sw-dot{width:6px;height:6px;border-radius:9999px;flex:none}
.watch-row:first-child{border-top:none}
.sev svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.sev.low{color:var(--fg-dim)}
.watch-b .wt{font-size:13px;line-height:1.4;color:var(--fg)}
.watch-b .ws{font-family:var(--fm);font-size:10px;color:var(--fg-muted);margin-top:3px;letter-spacing:.03em}
.watch-when.low{color:var(--fg-dim)}
.remind-row:first-child{border-top:none}
.remind-time.soft{color:var(--fg-muted)}
.remind-ico svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.5}
.remind-ico.ai{color:var(--ai-dim)}
.remind-ico.ai svg{fill:currentColor;stroke:none}
.chat::-webkit-scrollbar{width:6px}
.chat::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.msg.me{justify-content:flex-end}
.msg.me .bubble{background:var(--bg-selected);border:1px solid var(--border-strong);border-radius:14px 14px 4px 14px;color:var(--fg);max-width:82%}
.msg.ai{align-items:flex-start}
.msg .ava svg{width:13px;height:13px;fill:currentColor;stroke:none}
.bubble b{font-weight:600;color:var(--fg)}
.bubble .hl{color:var(--accent);font-variant-numeric:tabular-nums}
.bubble ul{margin:8px 0 0;padding-left:16px;display:flex;flex-direction:column;gap:5px}
.bubble li{font-size:13px;color:var(--fg-muted);line-height:1.45}
.bubble li b{color:var(--fg)}
.src-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:9px;padding-top:9px;border-top:1px solid var(--border)}
.src:hover{border-color:var(--border-strong);color:var(--fg)}
.src .sw-dot{width:6px;height:6px;border-radius:9999px;flex:none}
.composer .box input::placeholder{color:var(--fg-dim)}
.composer .send svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

/* ---------- landing overrides (pseudo / nested / state / media) ---------- */
.lp-eyebrow.ai{color:var(--ai)}
.lp-eyebrow .spark{width:12px;height:12px}
.lp-btn .k{font-family:var(--fm);font-size:11px;opacity:.7;font-weight:500}
.lp-btn.pri{background:var(--accent);color:var(--lp-ink);box-shadow:0 1px 0 rgba(255,255,255,.25) inset,0 8px 30px rgba(125,200,255,.28)}
.lp-btn.pri:hover{transform:translateY(-1px);box-shadow:0 1px 0 rgba(255,255,255,.3) inset,0 12px 40px rgba(125,200,255,.4)}
.lp-btn.ghost{background:rgba(255,255,255,.02);color:var(--fg);border-color:var(--lp-line-2)}
.lp-btn.ghost:hover{background:var(--bg-hover);border-color:var(--fg-muted);transform:translateY(-1px)}
.lp-btn.sm{padding:8px 14px;font-size:13px}
.lp-nav{position:sticky;top:0;z-index:50;background:rgba(7,8,10,.72);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--lp-line)}
.lp-nav .row{display:flex;align-items:center;gap:24px;height:62px}
.lp-brand .mark{width:18px;height:18px;display:flex;align-items:center;justify-content:center;color:var(--fg)}
.lp-brand .mark svg{width:100%;height:100%;display:block}
.lp-nav .links{display:flex;gap:26px;margin-left:8px}
.lp-nav .links a{color:var(--fg-muted);text-decoration:none;font-size:14px;transition:color .15s}
.lp-nav .links a:hover{color:var(--fg)}
.lp-nav .sp{flex:1}
.lp-nav .nauth{display:flex;align-items:center;gap:10px}
.lp-nav .nauth .txt{color:var(--fg-muted);font-size:14px;text-decoration:none}
.lp-nav .nauth .txt:hover{color:var(--fg)}
/* Language dropdown is now built entirely with UnoCSS utilities in Nav.astro
   (trigger + fly-out menu), driven by a data-open attribute on the wrapper.
   No .lp-lang* classes here — that avoids stray borders / double outlines. */
.lp-hero::before{content:"";position:absolute;inset:-20% -10% auto -10%;height:620px;pointer-events:none;background:radial-gradient(60% 100% at 50% 0%,rgba(125,200,255,.16),transparent 60%),radial-gradient(40% 80% at 78% 8%,rgba(198,184,244,.10),transparent 60%)}
.lp-hero .inner{position:relative;max-width:820px;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:22px}
.lp-hero .lp-h1{white-space:nowrap;max-width:none;font-size:clamp(30px,8vw,72px)}
.lp-hero .cta{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
.lp-hero .meta{font-family:var(--fm);font-size:11px;letter-spacing:.05em;color:var(--fg-dim);display:flex;gap:16px;flex-wrap:wrap;justify-content:center}
.lp-hero .meta b{color:var(--fg-muted);font-weight:500}
.lp-pill .tag{font-family:var(--fm);font-size:9.5px;letter-spacing:.06em;color:var(--lp-ink);background:var(--accent);border-radius:9999px;padding:2px 7px}
.lp-wall{position:relative;border-radius:16px;overflow:hidden;border:1px solid var(--lp-line-2);background:radial-gradient(120% 90% at 82% -10%,rgba(125,200,255,.16),transparent 52%),radial-gradient(90% 70% at 10% 110%,rgba(143,211,168,.08),transparent 55%),linear-gradient(165deg,#0d1218,#0a0d11 60%,#090b0e);box-shadow:0 40px 120px rgba(0,0,0,.6),0 2px 0 rgba(255,255,255,.03) inset;height:clamp(360px,46vw,540px)}
.lp-wall .macbar{border-radius:0;border-left:none;border-right:none;border-top:none;background:rgba(10,11,13,.66);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.lp-wall .macbar .pingr-tray{background:rgba(125,200,255,.12);border-color:rgba(125,200,255,.28)}
.lp-pop-drop{position:absolute;top:44px;right:clamp(16px,4vw,48px);width:360px;max-width:74vw}
.lp-pop-drop::before{content:"";position:absolute;top:-7px;right:26px;width:12px;height:12px;background:var(--bg);border-left:1px solid var(--border-strong);border-top:1px solid var(--border-strong);transform:rotate(45deg)}
.lp-pop-drop .popover{width:100%;box-shadow:0 30px 80px rgba(0,0,0,.62),0 0 0 1px rgba(255,255,255,.04)}
.lp-scene .caption{position:absolute;left:clamp(16px,4vw,40px);bottom:22px;max-width:270px}
.lp-scene .caption .t{font-size:15px;font-weight:600;letter-spacing:-.01em}
.lp-scene .caption .s{font-size:12.5px;color:var(--fg-muted);margin-top:3px}
.lp-logo .d{width:8px;height:8px;border-radius:9999px}
.lp-logo .soon{font-family:var(--fm);font-size:9px;letter-spacing:.05em;color:var(--fg-dim);border:1px solid var(--lp-line);border-radius:9999px;padding:1px 6px}
.lp-feature.rev .lp-copy{order:2}
.lp-feature + .lp-feature{margin-top:clamp(64px,9vw,116px)}
.lp-copy .lp-h2{margin-top:4px}
.lp-ul li b{color:var(--fg);font-weight:600}
.lp-ul .ic{width:18px;height:18px;margin-top:1px;color:var(--accent)}
.lp-ul .ic.ai{color:var(--ai)}
.lp-ul .ic svg{width:18px;height:18px;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.lp-mock{position:relative;border-radius:20px;padding:clamp(22px,3vw,40px);border:1px solid var(--lp-line);overflow:hidden;background:radial-gradient(90% 80% at 80% 0%,rgba(125,200,255,.08),transparent 55%),linear-gradient(160deg,#101319,#0b0e12);display:flex;justify-content:center;align-items:center;min-height:360px}
.lp-mock.ai{background:radial-gradient(90% 80% at 20% 0%,rgba(198,184,244,.12),transparent 55%),linear-gradient(160deg,#12111a,#0b0d12)}
.lp-mock .popover{box-shadow:0 30px 80px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.04)}
.lp-mock .tagchip{position:absolute;left:16px;top:16px;font-family:var(--fm);font-size:10px;letter-spacing:.06em;color:var(--fg-muted);background:rgba(0,0,0,.35);border:1px solid var(--lp-line);border-radius:9999px;padding:4px 10px}
.lp-stat .n .u{color:var(--accent)}
.lp-band{border-block:1px solid var(--lp-line);background:linear-gradient(180deg,rgba(255,255,255,.015),transparent)}
.lp-band .head{text-align:center;max-width:660px;margin:0 auto;display:flex;flex-direction:column;gap:16px;align-items:center}
.lp-pillar .ic{width:26px;height:26px;color:var(--accent)}
.lp-pillar .ic svg{width:26px;height:26px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.lp-final::before{content:"";position:absolute;inset:auto -10% -40% -10%;height:420px;background:radial-gradient(50% 100% at 50% 100%,rgba(125,200,255,.16),transparent 62%);pointer-events:none}
.lp-final .inner{position:relative;max-width:640px;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:20px}
.lp-footer .foot-top{display:flex;justify-content:space-between;align-items:center;gap:32px;flex-wrap:wrap}
.lp-footer .foot-brand{display:flex;flex-direction:column;gap:8px;max-width:340px}
.lp-footer .foot-tag{font-size:13px;color:var(--fg-muted);line-height:1.55}
.lp-footer .foot-links{display:flex;align-items:center;gap:22px;flex-wrap:wrap}
.lp-footer .foot-links a{color:var(--fg-muted);text-decoration:none;font-size:13.5px}
.lp-footer .foot-links a:hover{color:var(--fg)}
.ig-tile::after{content:"";position:absolute;inset:0;border-radius:inherit;background:radial-gradient(72% 60% at 50% -8%,var(--g,transparent),transparent 70%);opacity:.07;pointer-events:none;transition:opacity .18s}
.ig-tile:hover{transform:translateY(-3px);border-color:var(--border-strong);background:var(--bg-hover)}
.ig-tile:hover::after{opacity:.18}
.ig-logo img{width:28px;height:28px;object-fit:contain;display:block}
.ig-mono{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:var(--fm);font-size:10px;font-weight:600;color:var(--lp-ink);background:var(--m,var(--fg))}
.ig-txt{display:flex;flex-direction:column;align-items:center;gap:3px}
.ig-name{font-size:12.5px;font-weight:600;letter-spacing:-.01em}
.ig-auth{font-family:var(--fm);font-size:9.5px;letter-spacing:.06em;color:var(--fg-dim)}
.ig-tile.soon{opacity:.4}
.ig-tile.soon:hover{transform:none;background:var(--bg-raised);border-color:var(--border)}
.ig-tile.soon:hover::after{opacity:.07}
.ig-badge{position:absolute;top:6px;right:6px;font-family:var(--fm);font-size:8px;letter-spacing:.05em;color:var(--fg-dim);border:1px solid var(--border-strong);border-radius:9999px;padding:1px 6px;background:var(--bg)}
.ig-legend .item{display:inline-flex;align-items:center;gap:8px}
.ig-legend .k{font-family:var(--fm);font-size:10px;letter-spacing:.05em;color:var(--fg);border:1px solid var(--lp-line-2);border-radius:9999px;padding:3px 9px}
