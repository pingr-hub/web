---
// Privacy-by-architecture band · four pillars on how data stays local.
import { useTranslations, type Lang } from "../../i18n/ui";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="lp-section lp-band" id="privacy">
  <div class="lp-wrap">
    <div class="head">
      <span class="lp-eyebrow">{t("pv_eye")}</span>
      <h2 class="lp-h2" set:html={t("pv_h2")} />
      <p class="lp-lead" style="text-align:center" set:html={t("pv_lead")} />
    </div>
    <div class="lp-pillars">
      <div class="lp-pillar">
        <span class="ic"><svg viewBox="0 0 24 24"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg></span>
        <h3>{t("pv_p1t")}</h3>
        <p>{t("pv_p1p")}</p>
      </div>
      <div class="lp-pillar">
        <span class="ic"><svg viewBox="0 0 24 24"><rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/></svg></span>
        <h3>{t("pv_p2t")}</h3>
        <p>{t("pv_p2p")}</p>
      </div>
      <div class="lp-pillar">
        <span class="ic"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v12c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12c0 1.7 3.1 3 7 3s7-1.3 7-3"/></svg></span>
        <h3>{t("pv_p3t")}</h3>
        <p>{t("pv_p3p")}</p>
      </div>
      <div class="lp-pillar">
        <span class="ic"><svg viewBox="0 0 24 24"><path d="M4 12a8 8 0 0 1 8-8M20 12a8 8 0 0 1-8 8"/><path d="M4 4l16 16"/></svg></span>
        <h3>{t("pv_p4t")}</h3>
        <p>{t("pv_p4p")}</p>
      </div>
    </div>
  </div>
</section>
