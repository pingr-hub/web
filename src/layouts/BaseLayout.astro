---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pingr — All your notifications in one place." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — Pingr</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: #1a1a2e;
        background: #fafafa;
        line-height: 1.7;
      }
      header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e8e8e8;
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 800px;
        margin: 0 auto;
      }
      header a { text-decoration: none; color: #1a1a2e; font-weight: 600; font-size: 1.2rem; }
      nav a { color: #555; text-decoration: none; margin-left: 1.5rem; font-size: 0.9rem; }
      nav a:hover { color: #1a1a2e; }
      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }
      footer {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        border-top: 1px solid #e8e8e8;
        color: #999;
        font-size: 0.85rem;
        text-align: center;
      }
      h1 { font-size: 1.8rem; margin-bottom: 1.5rem; }
      h2 { font-size: 1.3rem; margin: 2rem 0 0.8rem; }
      p { margin-bottom: 1rem; color: #444; }
      ul { margin: 0.5rem 0 1rem 1.5rem; color: #444; }
      li { margin-bottom: 0.3rem; }
      a { color: #4a6cf7; }
    </style>
  </head>
  <body>
    <header>
      <a href="/">Pingr</a>
      <nav>
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      &copy; {new Date().getFullYear()} Pingr. All rights reserved.
    </footer>
  </body>
</html>
